      rij[0]=0; rij[1]=0; rij[2]=-1;
      E+= bulk_potentialGPU(ni,nj,params,rij);
    }
    float s[3]={fullni[7].x,fullni[7].y,fullni[7].z};
    if (fullni[0].pt>1) E+= d_Surface_Potential_GPU[fullni[0].pt-2](ni,s);
  return E;
}

__device__ float Homeotropic_Surface_Potential_GPU(float ni[3], float s[3]){
  
  float nij=ni[0]*s[0]+ni[1]*s[1]+ni[2]*s[2];
  return -nij*nij;
}

__device__ float FG_Surface_Potential_GPU(float ni[3], float s[3]){

  float nij=ni[0]*s[0]+ni[1]*s[1]+ni[2]*s[2];
  return +nij*nij;
}
